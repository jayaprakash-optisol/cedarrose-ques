# ── Database ──────────────────────────────────────────
PGHOST=
PGUSER=
PGPORT=
PGDATABASE=
PGPASSWORD=
DATABASE_URL=

# ── JWT Keys (RS256 — asymmetric) ────────────────────
# Provide either the PEM contents directly, a base64-encoded PEM, or a .pem file path.
# File paths are the recommended approach:

# Access token keys (staff login)
JWT_ACCESS_PRIVATE_KEY_PATH=keys/access-private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=keys/access-public.pem

# Questionnaire session keys (OTP flow)
JWT_QUESTIONNAIRE_PRIVATE_KEY_PATH=keys/questionnaire-private.pem
JWT_QUESTIONNAIRE_PUBLIC_KEY_PATH=keys/questionnaire-public.pem

# Alternatively, set inline (base64 of PEM):
# JWT_ACCESS_PRIVATE_KEY=<base64-encoded-pem>
# JWT_ACCESS_PUBLIC_KEY=<base64-encoded-pem>

# JWT Configuration
JWT_ISSUER=cedarrose-api
JWT_AUDIENCE=cedarrose-client
JWT_ACCESS_TOKEN_EXPIRY=1d
JWT_REFRESH_TOKEN_DAYS=30
JWT_QUESTIONNAIRE_TOKEN_EXPIRY=15m
JWT_ALGORITHM=RS256

# Password Security
BCRYPT_ROUNDS=10

# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
ALLOWED_EXTERNAL_HOSTS=data-exchange.cedarrose.com

# ── Azure Email ───────────────────────────────────────
# Format: endpoint=https://<resource>.communication.azure.com/;accesskey=<key>
AZURE_EMAIL_CONNECTION_STRING=
AZURE_EMAIL_SENDER=

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
