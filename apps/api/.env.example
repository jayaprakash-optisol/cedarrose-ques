# ── Database ──────────────────────────────────────────
PGHOST=
PGUSER=
PGPORT=
PGDATABASE=
PGPASSWORD=
DATABASE_URL=

# ── Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-64
QUESTIONNAIRE_JWT_SECRET=change-me-use-openssl-rand-hex-64

# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
ALLOWED_EXTERNAL_HOSTS=data-exchange.cedarrose.com

# ── Azure Email ───────────────────────────────────────
# Format: endpoint=https://<resource>.communication.azure.com/;accesskey=<key>
AZURE_EMAIL_CONNECTION_STRING=
AZURE_EMAIL_SENDER=

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
