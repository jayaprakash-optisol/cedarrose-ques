[
  {
    "id": "tpl-1",
    "name": "Standard Due Diligence — Supplier",
    "recipientType": "Supplier",
    "status": "Active",
    "lastEdited": "2 May 2026",
    "editor": "David Chen",
    "sections": [
      {
        "id": "sec-1",
        "number": 1,
        "title": "General Company Information",
        "questions": [
          {
            "id": "q1-1",
            "text": "Full Legal Name",
            "type": "text",
            "required": true,
            "prefill": true,
            "helpText": "Unique name — must match official registration exactly. Max 200 characters.",
            "validation": {
              "maxLength": 200
            }
          },
          {
            "id": "q1-2",
            "text": "Other Trading Name(s)",
            "type": "text",
            "required": false,
            "prefill": true,
            "helpText": "Optional. Use the Add another button to enter multiple trading names.",
            "repeater": true
          },
          {
            "id": "q1-3",
            "text": "Registered Address",
            "type": "longtext",
            "required": true,
            "prefill": true,
            "helpText": "Multi-line address field."
          },
          {
            "id": "q1-4",
            "text": "Operational Address",
            "type": "longtext",
            "required": false,
            "prefill": false,
            "helpText": "Separate from registered address. Show 'Same as above' toggle below this field.",
            "sameAsToggleLabel": "Same as registered address"
          },
          {
            "id": "q1-5",
            "text": "Other Branches",
            "type": "longtext",
            "required": false,
            "prefill": false,
            "helpText": "Optional. Use Add branch button for multi-location capture.",
            "repeater": true
          },
          {
            "id": "q1-6",
            "text": "Telephone Number(s)",
            "type": "text",
            "required": true,
            "prefill": true,
            "helpText": "Include country code. Format validated automatically."
          },
          {
            "id": "q1-7",
            "text": "Mobile Number",
            "type": "text",
            "required": false,
            "prefill": false,
            "helpText": "Same format as telephone. May be used for OTP verification."
          },
          {
            "id": "q1-8",
            "text": "Email",
            "type": "text",
            "required": true,
            "prefill": true,
            "helpText": "Standard email format validation (@domain.com)."
          },
          {
            "id": "q1-9",
            "text": "Web Page",
            "type": "url",
            "required": false,
            "prefill": false,
            "helpText": "URL format. https:// prefix required."
          },
          {
            "id": "q1-10",
            "text": "Premises Type",
            "type": "multiselect",
            "required": true,
            "prefill": false,
            "options": [
              "Office",
              "Factory",
              "Warehouse",
              "Showroom"
            ],
            "helpText": "Select all that apply."
          },
          {
            "id": "q1-11",
            "text": "Owned / Rented",
            "type": "radio",
            "required": true,
            "prefill": false,
            "options": [
              "Owned",
              "Rented"
            ],
            "helpText": "Select one option."
          },
          {
            "id": "q1-12",
            "text": "Premises Size (sqm)",
            "type": "number",
            "required": false,
            "prefill": false,
            "helpText": "Numeric only. Minimum 0. Unit: sqm.",
            "validation": {
              "min": 0
            }
          }
        ]
      },
      {
        "id": "sec-2",
        "number": 2,
        "title": "Registration Information",
        "questions": [
          {
            "id": "q2-1",
            "text": "Commercial Registration Number",
            "type": "text",
            "required": true,
            "prefill": true,
            "helpText": "Alphanumeric. Format: XX-000000."
          },
          {
            "id": "q2-2",
            "text": "Legal Form",
            "type": "dropdown",
            "required": true,
            "prefill": true,
            "options": [
              "LLC",
              "JSC",
              "Branch",
              "Sole Proprietor",
              "Partnership",
              "Other"
            ],
            "helpText": "Select the legal structure of the entity."
          },
          {
            "id": "q2-3",
            "text": "Registered Date",
            "type": "date",
            "required": true,
            "prefill": true,
            "helpText": "Format: DD/MM/YYYY.",
            "validation": {
              "allowPast": true,
              "allowFuture": false
            }
          },
          {
            "id": "q2-4",
            "text": "Expiry Date",
            "type": "date",
            "required": false,
            "prefill": false,
            "helpText": "If past today's date, subject will be prompted to upload updated document.",
            "validation": {
              "allowPast": true,
              "allowFuture": true
            }
          },
          {
            "id": "q2-5",
            "text": "Trade License",
            "type": "text",
            "required": true,
            "prefill": false,
            "helpText": "Alphanumeric license number. Pair with file upload for the license scan.",
            "attachUpload": true
          },
          {
            "id": "q2-6",
            "text": "VAT Number",
            "type": "text",
            "required": false,
            "prefill": false,
            "helpText": "Country-specific format. Format hint shown below field."
          },
          {
            "id": "q2-7",
            "text": "Tax Number",
            "type": "text",
            "required": false,
            "prefill": false,
            "helpText": "Similar to VAT. Optional based on jurisdiction."
          },
          {
            "id": "q2-8",
            "text": "Company National ID",
            "type": "text",
            "required": false,
            "prefill": false,
            "helpText": "Country-specific. Masked input if format is known."
          }
        ]
      },
      {
        "id": "sec-3",
        "number": 3,
        "title": "Ownership (Shareholders / Partners)",
        "banner": "This section uses a repeating row table. Each row captures one shareholder. The subject can add or remove rows. Minimum 1 row required.",
        "questions": [
          {
            "id": "q3-1",
            "text": "Shareholders",
            "type": "table",
            "required": true,
            "prefill": false,
            "helpText": "One row per shareholder. Subject can add/remove rows.",
            "columns": [
              {
                "name": "Shareholder Name",
                "type": "text",
                "required": true
              },
              {
                "name": "Nationality",
                "type": "dropdown",
                "required": true
              },
              {
                "name": "Ownership %",
                "type": "number",
                "required": true
              },
              {
                "name": "No. of Shares",
                "type": "number",
                "required": false
              }
            ]
          }
        ]
      },
      {
        "id": "sec-4",
        "number": 4,
        "title": "Directors",
        "banner": "This section uses a repeating row table. Each row captures one director.",
        "questions": [
          {
            "id": "q4-1",
            "text": "Directors",
            "type": "table",
            "required": true,
            "prefill": false,
            "helpText": "Same row-repeater pattern as shareholders. Role options: Chairman, Vice Chairman, CEO, Board Member, CFO, Other.",
            "columns": [
              {
                "name": "Director Name",
                "type": "text",
                "required": true
              },
              {
                "name": "Nationality",
                "type": "dropdown",
                "required": true
              },
              {
                "name": "Role / Title",
                "type": "dropdown",
                "required": true
              }
            ]
          }
        ]
      }
    ]
  },
